PORT=4100
FRONTEND_ORIGIN=http://localhost:8999
CANAL_PLUS_SECRET=replace-with-a-32-byte-random-secret
CANAL_PLUS_METADATA_DSN=root:password@tcp(127.0.0.1:3306)/canal_plus?parseTime=true
CANAL_PLUS_METADATA_TABLE_PREFIX=canal_plus
CANAL_PLUS_NODE_ID=node-shanghai-a
CANAL_PLUS_NODE_NAME=shanghai-a
CANAL_PLUS_NODE_ENDPOINT=127.0.0.1:4100
CANAL_PLUS_NODE_ROLE=scheduler+worker
CANAL_PLUS_NODE_ZONE=local
CANAL_PLUS_NODE_CAPACITY=1
CANAL_PLUS_CLUSTER_SUPERVISOR=true
CANAL_PLUS_CLUSTER_SUPERVISOR_INTERVAL_SECONDS=5
CANAL_PLUS_EMBEDDED_NODE_HEARTBEAT=true
CANAL_PLUS_EMBEDDED_NODE_HEARTBEAT_INTERVAL_SECONDS=10
